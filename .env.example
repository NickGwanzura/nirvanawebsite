# MongoDB Connection String
# Get your free MongoDB Atlas cluster at https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nirvana-pilates?retryWrites=true&w=majority

# Optional: For production
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Admin Authentication (REQUIRED — set these in your deployment environment)
# ADMIN_PASSWORD — the password used to log in at /admin/login
ADMIN_PASSWORD=change-me-to-a-strong-password
# ADMIN_SECRET — random string used to sign the session token; generate with: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-random-secret-string
